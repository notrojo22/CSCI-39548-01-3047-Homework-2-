# Copy this file to .env and fill in your own values. Never commit .env.

# Get this from MongoDB Atlas: Database > Connect > Drivers > copy the connection string,
# then replace <password> with your database user's password and add a database name
# before the "?" (example below uses "dailycrave").
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/dailycrave?retryWrites=true&w=majority

# Port the Express server will listen on
PORT=5000

# The origin your Vite dev server runs on, so CORS allows it
CLIENT_ORIGIN=http://localhost:5173
